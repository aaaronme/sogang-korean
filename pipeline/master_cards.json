  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "はい、知（し）っています。"
 },
 {
  "id": "8e3a879fb2",
  "ko": "렌핑 씨 생일이 며칠이에요?",
  "en": "What date is Lenping's birthday?",
  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "レンピンさんの誕生日（たんじょうび）は何日（なんにち）ですか？"
