  ],
  "ja": "傘（かさ）はありますか？"
 },
 {
  "id": "fbafcf654f",
  "ko": "네, 있어요.",
  "en": "Yes, I do.",
  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "はい、あります。"
 },
 {
  "id": "7f2c0980cd",
  "ko": "아니요, 없어요.",
  "en": "No, I don't.",
  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "いいえ、ありません。"
 },
 {
  "id": "8d3397219e",
  "ko": "책 있어요.",
  "en": "I have a book.",
  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "本（ほん）があります。"
 },
 {
  "id": "f887735b31",
  "ko": "안경 없어요.",
  "en": "I don't have glasses.",
  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "めがねはありません。"
 },
 {
  "id": "de2f2116bf",
  "ko": "지금 핸드폰 있어요?",
  "en": "Do you have your phone now?",
  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "今（いま）、携帯電話（けいたいでんわ）はありますか？"
 },
 {
  "id": "ec06faebca",
  "ko": "네, 핸드폰 있어요.",
  "en": "Yes, I have my phone.",
  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "はい、携帯電話（けいたいでんわ）があります。"
 },
 {
  "id": "2baccdb4ac",
  "ko": "아니요, 핸드폰 없어요.",
  "en": "No, I don't have my phone.",
  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "いいえ、携帯電話（けいたいでんわ）はありません。"
 },
 {
  "id": "02e9df6345",
  "ko": "수잔 씨, 한국 전화번호 있어요?",
  "en": "Susan, do you have a Korean phone number?",
  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "スーザンさん、韓国（かんこく）の電話番号（でんわばんごう）はありますか？"
 },
 {
  "id": "cddcc9bf42",
  "ko": "전화번호가 몇 번이에요?",
  "en": "What's your phone number?",
  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "電話番号（でんわばんごう）は何番（なんばん）ですか？"
 },
 {
  "id": "719c6677b6",
  "ko": "010-4948-1287이에요.",
  "en": "It's 010-4948-1287.",
  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "010-4948-1287です。"
 },
 {
  "id": "374e654453",
  "ko": "네, 맞아요.",
  "en": "Yes, that's right.",
  "tags": [
   "Book1A::Prep3::Sentences"
  ],
  "ja": "はい、そうです。"
 },
 {
  "id": "45cf017f2f",
  "ko": "완 씨, 렌핑 씨 생일 알아요?",
